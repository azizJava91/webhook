# Sunucuda: /root/carland.env
# Tum carland stack servisleri bu dosyayi env_file ile okur.

# --- RabbitMQ container ---
RABBITMQ_DEFAULT_USER=webhook
RABBITMQ_DEFAULT_PASS=carcatmq

# --- Webhook -> RabbitMQ baglantisi ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=webhook
RABBITMQ_PASSWORD=carcatmq

# --- Webhook service ---
SERVER_PORT=8080
CARLAND_BASE_URL=http://carland-service:9091

# Webhook -> Carland internal auth (carland tarafinda da ayni deger)
CARLAND_INTERNAL_TOKEN=degistir-uzun-rastgele-token

# Sonraki adimlarda eklenecek:
# WEBHOOK_SECRET=

# --- Carland service (mevcut) ---
# CARLAND_INTERNAL_TOKEN=degistir-uzun-rastgele-token
# DB_URL=jdbc:postgresql://cardb:5432/...
# DB_USERNAME=
# DB_PASSWORD=
# MAIL_USERNAME=
# MAIL_PASSWORD=
# SUPER_ADMIN_PHONE=
# HYPER_CLIENT_ID=
# HYPER_CLIENT_SECRET=
# BREVO_API_KEY=
